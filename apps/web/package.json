    "verify:phase3c": "node --conditions=react-server --import dotenv/config --import tsx scripts/verify-phase3c.ts",
    "verify:phase5": "node --conditions=react-server --import dotenv/config --import tsx scripts/verify-phase5.ts",
    "verify:phase7": "node --conditions=react-server --import dotenv/config --import tsx scripts/verify-phase7.ts",
    "verify:phase8.5": "node --conditions=react-server --import dotenv/config --import tsx scripts/verify-phase8-5.ts",
    "verify:phase8.6": "node --conditions=react-server --import dotenv/config --import tsx scripts/verify-phase8-6.ts",
    "verify:phase8.7": "node --conditions=react-server --import dotenv/config --import tsx scripts/verify-phase8-7.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",

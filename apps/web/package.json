    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "latest",
    "@types/node": "latest",
    "@types/pg": "^8.20.0",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "prisma": "^7.8.0",
    "tailwindcss": "latest",
    "tsx": "^4.22.4",
    "typescript": "latest"
  }

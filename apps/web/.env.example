# Local PostgreSQL
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/humanbase?schema=public"

# Optional: direct/admin connection for Prisma CLI, pg_dump and pg_restore.
# Leave empty for local development if DATABASE_URL already points directly to PostgreSQL.
DIRECT_URL=""

# Supabase Auth. Use the project's publishable key.
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Comma-separated app-level allowlist. Only these signed-in Supabase Auth
# emails may access Humanbase data.
HUMANBASE_ALLOWED_EMAILS="you@example.com"
